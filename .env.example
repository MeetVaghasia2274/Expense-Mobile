# === Supabase Configuration ===
# The URL of your Supabase project (e.g. https://xyzcompany.supabase.co)
EXPO_PUBLIC_SUPABASE_URL="your_supabase_url_here"

# The anon public key for your Supabase project
EXPO_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# === Voice / AI API (Phase 2) ===
# Optional: OpenAI API Key if switching from local regex NLP to LLM parsing
EXPO_PUBLIC_OPENAI_API_KEY="your_openai_api_key_here"
